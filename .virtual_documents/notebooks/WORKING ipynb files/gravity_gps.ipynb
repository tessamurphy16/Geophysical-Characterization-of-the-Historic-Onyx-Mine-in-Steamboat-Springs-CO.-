import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from pyproj import Transformer


file_path = "../../data/gravity/raw_data/gravity_05_27_2026.csv"

df = pd.read_csv(file_path)
df.head()



plt.figure(figsize=(4, 4))

plt.scatter(
    df["Longitude"],
    df["Latitude"],
    s=20
)

plt.xlabel("Longitude")
plt.ylabel("Latitude")
plt.title("GPS Point Locations")
plt.grid(True)

plt.show()


gps = df[["Name", "Longitude", "Latitude", "Ellipsoidal height"]].copy()

gps = gps.rename(columns={
    "Name": "station",
    "Ellipsoidal height": "elevation_m"
})

gps.head(36)


gps.to_csv("gps_points_with_elevation.csv", index=False)



